# Cóndor — environment variables (Phase 2)
# Copy to .env.local and fill with real values from the Supabase dashboard.
# .env.local is gitignored. NEVER commit real secrets.

# Supabase project: svgphkbtspqgsliqbsfx
# Project URL — client-safe.
NEXT_PUBLIC_SUPABASE_URL=https://svgphkbtspqgsliqbsfx.supabase.co

# Publishable (client) key — safe to ship to the browser; RLS-guarded.
# Supabase dashboard → Project Settings → API Keys → Publishable key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<from Supabase dashboard: API Keys → Publishable key>

# Secret (server-only) key — NEVER expose to the client, NEVER prefix with NEXT_PUBLIC_.
# Supabase dashboard → Project Settings → API Keys → Secret key.
SUPABASE_SECRET_KEY=<from Supabase dashboard: API Keys → Secret key (server-only)>
